{
  "$schema": "https://unpkg.com/knip@3/schema-jsonc.json",
  "ignoreWorkspaces": [
    "packages/sheriff-utils",
    "apps/config-validation-playground",
    "apps/cli-playground",
    "apps/docs-website",
  ],
  "ignore": [
    "packages/sheriff-create-config/src/utils/gracefullyAbort.ts",
    "packages/sheriff-cli/src/utils/gracefullyAbort.ts",
  ],
  "ignoreDependencies": [
    "@arethetypeswrong/cli",
    "@turbo/gen",
    "eslint-import-resolver-typescript",
  ],
  "ignoreBinaries": ["only-allow"],
}
