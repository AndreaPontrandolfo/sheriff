{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "src/components/ui",
    "src/components/magicui",
    ".output"
  ],
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "resolveJsonModule": true,
    "jsx": "preserve",
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "paths": {
      "collections/*": [".source/*"],
      "@/*": ["./src/*"]
    }
  }
}
